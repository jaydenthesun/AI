# Clōd (OpenAI-compatible) — required for live tutor + review generation
CLOD_API_KEY=
CLOD_BASE_URL=https://api.clod.io/v1
CLOD_MODEL=DeepSeek V3

# AllScale — specialized course checkout (https://docs.allscale.io/allscale-checkout)
ALLSCALE_API_KEY=
ALLSCALE_API_SECRET=
# Optional override (default https://openapi.allscale.io)
ALLSCALE_API_BASE=https://openapi.allscale.io
# Public origin for post-payment redirect (e.g. https://your-domain.com or http://127.0.0.1:3456)
NEXT_PUBLIC_APP_URL=
# Greptile — optional indexed-repo context for code review + understanding
GREPTILE_API_KEY=
GREPTILE_GITHUB_TOKEN=
GREPTILE_REPOSITORY=owner/repo
GREPTILE_REMOTE=github
GREPTILE_BRANCH=main
GREPTILE_BASE_URL=https://api.greptile.com/v2
